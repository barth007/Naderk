# Copy this file to .env (local dev) or .env.production (server) and fill in real values.
# Never commit files with real credentials.

DJANGO_SETTINGS_MODULE=config.settings.production   # change to config.settings.local for local dev
API_BASE_URL=https://api.naderkela.com
DEBUG=False
SECRET_KEY=replace-with-a-long-random-string

DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/naderk_db

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
REDIS_URL=redis://redis:6379/0

ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Email provider: postmark | smtp | resend | ses
EMAIL_PROVIDER=postmark

# Postmark (recommended for production)
POSTMARK_SERVER_TOKEN=your-postmark-server-api-token
POSTMARK_MESSAGE_STREAM=outbound
POSTMARK_WEBHOOK_TOKEN=your-webhook-auth-token
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
DEFAULT_REPLY_TO_EMAIL=support@yourdomain.com

# SMTP fallback (used when EMAIL_PROVIDER=smtp)
EMAIL_HOST=mail.privateemail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your@email.com
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True

# Brand / frontend
BRAND_NAME=NaderkEye Care
BRAND_LOGO_URL=https://yourdomain.com/logo.png
FRONTEND_URL=https://yourdomain.com

# Cloudinary (image storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# LiveKit (WebRTC video)
LIVEKIT_URL=ws://livekit:7880
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Paystack (payments)
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=
