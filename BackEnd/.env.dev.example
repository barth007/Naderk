# Copy this file to .env (local dev) or .env.production (server) and fill in real values.
# Never commit files with real credentials.

DEBUG=False
SECRET_KEY=replace-with-a-long-random-string

DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/naderk_db

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
REDIS_URL=redis://redis:6379/0

ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Email (Privateemail / SMTP)
EMAIL_HOST=mail.privateemail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your@email.com
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=your@email.com

# Cloudinary (image storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# LiveKit (WebRTC video)
LIVEKIT_URL=ws://livekit:7880
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Paystack (payments)
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=
